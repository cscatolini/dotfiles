[user]
  name = Camila Scatolini
  email = camila.scatolini@gmail.com

[includeIf "gitdir:/Users/cscatolini/code/sanar/"]
  path = ~/.gitconfig-sanar

[core]
  editor = emacs -nw
  excludesfile = /Users/cscatolini/.gitignore_global
  whitespace = fix,-indent-with-non-tab,trailing-space,space-before-tab,cr-at-eol
  fsmonitor = true
  untrackedCache = true

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[rebase]
  autoStash = true

[rerere]
  enabled = true

[diff]
  algorithm = histogram

[merge]
  conflictstyle = zdiff3

[credential]
  helper = osxkeychain

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[alias]
  purr      = pull --rebase
  fastamend = commit --amend --no-edit
  undo      = reset HEAD~1 --mixed
  st        = status
  ci        = commit
  br        = branch
  co        = checkout
  sw        = switch
  df        = diff
  lg        = log -p
  lol       = log --graph --pretty=format:'%C(yellow)%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cblue(%cr)%Creset' --abbrev-commit --date=relative
  lola      = log --graph --pretty=format:'%C(yellow)%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cblue(%cr)%Creset' --abbrev-commit --date=relative --all
  ls        = ls-files

[color]
  ui = true

[color "branch"]
  current = yellow reverse
  local   = yellow
  remote  = green

[color "diff"]
  meta       = yellow bold
  frag       = magenta bold
  old        = red bold
  new        = green bold
  whitespace = red reverse

[color "status"]
  added     = green
  changed   = yellow
  untracked = red

[branch]
  autosetupmerge = true
